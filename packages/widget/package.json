{
  "name": "ucl-chat-widget",
  "version": "0.2.6",
  "description": "Reusable LLM chat widget for Next.js applications",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./styles/globals.css": "./src/styles/globals.css"
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepare": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "next": ">=15.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "ucl-study-llm-chat-api": "file:../../../ucl-study-llm-chat-api/ucl-study-llm-chat-api-1.0.5.tgz"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.118",
    "@assistant-ui/react": "^0.12.15",
    "@assistant-ui/react-ai-sdk": "^1.3.12",
    "@assistant-ui/react-markdown": "^0.12.5",
    "@base-ui/react": "^1.2.0",
    "ai": "^6.0.116",
    "assistant-stream": "^0.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "tsup": "^8.5.0",
    "typescript": "^5",
    "ucl-study-llm-chat-api": "file:../../../ucl-study-llm-chat-api/ucl-study-llm-chat-api-1.0.5.tgz",
    "vitest": "^4.0.18"
  }
}
